# Copy this file to .env and fill in real values before deploying.

# Port the server listens on (most hosts set this automatically)
PORT=3000

# Secret key required to view /admin.html and the /api/admin/* endpoints.
# Change this to a long random string before deploying.
ADMIN_KEY=changeme

# --- Lead notifications (Resend — free tier: 100 emails/day) ---
# Sign up at https://resend.com, verify your domain (or use onboarding@resend.dev for testing)
RESEND_API_KEY=
NOTIFY_EMAIL=hindustangroupjammu@gmail.com
FROM_EMAIL=Hindustan Group <onboarding@resend.dev>

# --- Paid consultations via Stripe (optional — direct revenue) ---
# Create products at https://dashboard.stripe.com — use test keys while developing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Your live site URL, no trailing slash (e.g. https://axion-technologies.onrender.com)
SITE_URL=http://localhost:3000
# Price in cents for the 60-min strategy session (default: $199)
CONSULTATION_PRICE_CENTS=19900
